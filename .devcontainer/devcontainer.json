{
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu-24.04",
  "mounts": [
    "source=bazel-cache,target=/home/vscode/.cache/bazel,type=volume",
    "source=bazelisk-cache,target=/home/vscode/.cache/bazelisk,type=volume"
  ],
  "features": {
    "ghcr.io/ezhuk/devcontainer-features/bazel:1": {},
    "ghcr.io/ezhuk/devcontainer-features/cmake:1": {},
    "ghcr.io/ezhuk/devcontainer-features/ninja:1": {},
    "ghcr.io/ezhuk/devcontainer-features/uv:1": {},
    "ghcr.io/ezhuk/devcontainer-features/vcpkg:1": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "BazelBuild.vscode-bazel",
        "ms-vscode.cmake-tools",
        "ms-vscode.cpptools"
      ]
    }
  }
}
